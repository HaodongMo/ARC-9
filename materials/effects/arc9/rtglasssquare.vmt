"VertexlitGeneric"
{
	"$basetexture"             "effects/arc9/glass2"
	"$bumpmap"                 "effects/arc9/glass_nm"
	// "$translucent" 1
    "$additive" "1"
	
	"$softwareskin" "1"
	"$phong" "1"
	"$phongboost" "0.4"
	// "$phongalbedotint" "1"
	"$phongexponent" "1000"
	"$phongfresnelranges" "[5.22 5.856 20]"
	"$phongtint" "[1.3 1.1 1.5]"

	"$envmap" "env_cubemap"
	"$envmaptint" "[1 1 1]"
	"$envmapfresnel" "0.17"
	"$normalmapalphaenvmapmask" "0"
	"$basemapalphaenvmapmask" "0"

	// "$halflambert" 1

	"Proxies"
	{
		"arc9_scope_alpha"
		{
           "color" "[1.3 1.1 1.5]"
           "max" "0.5"
			"resultVar" "$envmaptint"
		}
	}
}
