screenspace_general
{
	$pixshader "testdofDEBUG5_ps30"
	$vertexshader 	"arc9_pp_vs30"

	$basetexture "_rt_FullFrameFB"
	$texture1    "_rt_ResolvedFullFrameDepth"

	$vertexcolor 1
	$vertextransform 1
	$ignorez        1
	$fix_fb         32768
	"<dx90"
	{
		$no_draw 1
	}
	
	$copyalpha                 1
	$alpha_blend_color_overlay 0
	$alpha_blend               0
	$linearwrite               0
	$linearread_basetexture    0
	$linearread_texture1       0
	$linearread_texture2       0
	$linearread_texture3       0

	$c0_x     8
	$c0_y     8
	$c0_z     0.07

	$c1_x     1.0/2560
	$c1_y     1.0/1440
}
