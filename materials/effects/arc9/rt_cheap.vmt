"UnlitGeneric"
{
	"$basetexture" "_rt_FullFrameFB"
	"$ignorez" "1"
	"$scale1" "0.85"
	"$scale2" "1"
	"$scale3" "0.85"
	// "$translucent" "1"
	// "$vertexalpha" "1"
	"Proxies"
	{
		"Multiply"
		{
			"srcVar1" "$scale1"
			"srcVar2" "$scale2"
			"resultvar" "$scale3"
		}
		"texturetransform"
		{
			"scalevar" "$scale3"
			"resultvar" "$basetexturetransform"
		}
	}
}