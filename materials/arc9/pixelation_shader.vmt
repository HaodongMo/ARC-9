screenspace_general 
{
	$pixshader "arc9lens_pixely5_ps30"
	$texture1 "effects/arc9/pixelshadermask"
	$basetexture "_rt_FullFrameFB"
	$ignorez 1
	$vertextransform 1
	$model 1
	
	// C0.x = Base Grid Size (e.g., 100.0 for a 100-cell vertical grid)
	// C0.y = Screen Aspect Ratio (Width / Height, e.g., 1.777 for 16:9)
	// C0.z = Grid Line Thickness (e.g., 0.05 for thin lines, 0.1 for thicker lines)

	$c0_x 200
	$c0_y 1.15
	$c0_z 1.7777
}