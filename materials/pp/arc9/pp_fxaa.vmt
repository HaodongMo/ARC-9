screenspace_general
{
	$pixshader 		"arc9_fxaa_ps30"
	$vertexshader 	"arc9_fxaa_vs30"

	$basetexture 		"_rt_FullFrameFB"

	$VertexColor 1
	$ignorez 1
	$fix_fb         32768
	"<dx90"
	{
		$no_draw 1
	}

	//$linearread_basetexture    1
	
	Proxies
	{
		Equals
		{
			srcVar1			$fix_fb
			resultVar		$flags2
		}
	}
}
